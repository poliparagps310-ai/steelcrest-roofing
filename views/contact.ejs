<%- include('partials/header') %>

<main class="pt-20">
    <!-- Contact Hero Section -->
    <section class="bg-primary text-on-primary py-24 relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-primary-container via-primary to-primary opacity-80"></div>
        <div class="absolute -left-20 -bottom-20 w-96 h-96 bg-secondary-container/10 rounded-full blur-3xl"></div>
        
        <div class="max-w-7xl mx-auto px-margin-desktop text-center relative z-10">
            <span class="font-label-caps text-secondary-container text-sm tracking-widest block mb-4">GET IN TOUCH</span>
            <h1 class="font-display-lg text-display-lg text-on-primary mb-6">Request A Consultation</h1>
            <p class="font-body-lg text-on-primary-container max-w-2xl mx-auto">Connect with our architectural project team for a comprehensive, commercial-grade evaluation or residential estate inspection.</p>
        </div>
    </section>

    <!-- Contact details & Form Container -->
    <section class="py-section-gap bg-surface">
        <div class="max-w-7xl mx-auto px-margin-desktop">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
                
                <!-- Left Column: Contact Cards & Map -->
                <div class="lg:col-span-5 space-y-8">
                    <div>
                        <span class="font-label-caps text-secondary text-sm tracking-widest block mb-2">OFFICE DETAILS</span>
                        <h2 class="font-display-lg text-headline-md mb-6">Headquarters</h2>
                    </div>

                    <!-- Location Card -->
                    <div class="bg-surface-container-lowest p-8 border-l-4 border-secondary-container premium-shadow flex gap-6 items-start transition-transform duration-300 hover:translate-x-1">
                        <span class="material-symbols-outlined text-secondary text-3xl">location_on</span>
                        <div class="space-y-2">
                            <h3 class="font-button-text text-xl text-primary">Office Address</h3>
                            <p class="font-body-md text-on-surface-variant">123 Austin Way,<br>Austin, TX 78701</p>
                        </div>
                    </div>

                    <!-- Direct Reach Card -->
                    <div class="bg-surface-container-lowest p-8 border-l-4 border-secondary-container premium-shadow flex gap-6 items-start transition-transform duration-300 hover:translate-x-1">
                        <span class="material-symbols-outlined text-secondary text-3xl">phone_in_talk</span>
                        <div class="space-y-2">
                            <h3 class="font-button-text text-xl text-primary">Direct Contact</h3>
                            <p class="font-body-md text-on-surface-variant">Phone: (512) 555-0191</p>
                            <p class="font-body-md text-on-surface-variant">Email: info@steelcrestroofing.com</p>
                        </div>
                    </div>

                    <!-- Hours Card -->
                    <div class="bg-surface-container-lowest p-8 border-l-4 border-secondary-container premium-shadow flex gap-6 items-start transition-transform duration-300 hover:translate-x-1">
                        <span class="material-symbols-outlined text-secondary text-3xl">schedule</span>
                        <div class="space-y-2">
                            <h3 class="font-button-text text-xl text-primary">Operating Hours</h3>
                            <p class="font-body-md text-on-surface-variant">Monday – Friday: 8:00 AM – 6:00 PM</p>
                            <p class="font-body-md text-on-surface-variant">Saturday: 9:00 AM – 3:00 PM</p>
                            <p class="font-body-md text-on-surface-variant text-secondary">Sunday: 24/7 Emergency Repairs Only</p>
                        </div>
                    </div>

                    <!-- Map Placeholder -->
                    <div class="overflow-hidden rounded-lg premium-shadow border border-outline-variant/30">
                        <iframe class="w-full h-80 border-0" src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d110204.7463724213!2d-97.8561019!3d30.2764129!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8644b599a0c247bb%3A0x2509e6a5763dbb47!2sAustin%2C%20TX!5e0!3m2!1sen!2sus!4v1715830000000!5m2!1sen!2sus" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                    </div>
                </div>

                <!-- Right Column: Consultation Booking Form -->
                <div class="lg:col-span-7 bg-surface-container-low p-8 sm:p-12 rounded-lg premium-shadow border border-outline-variant/20">
                    <div class="mb-8">
                        <span class="font-label-caps text-secondary text-sm tracking-widest block mb-2">INSPECTION REQUEST</span>
                        <h2 class="font-display-lg text-headline-md">Schedule An Assessment</h2>
                    </div>

                    <form id="contact-form" class="space-y-6">
                        <!-- Web3Forms API Key Access Configuration -->
                        <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_ACCESS_KEY_HERE">
                        <input type="hidden" name="subject" value="New Inspection Request - SteelCrest Roofing">
                        <input type="checkbox" name="botcheck" id="" style="display: none;">

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                            <!-- Name -->
                            <div class="flex flex-col">
                                <label class="font-label-caps text-xs text-on-surface-variant mb-2" for="name">Your Name</label>
                                <input class="font-body-md bg-transparent border-b border-outline-variant py-2 focus:border-secondary-container focus:outline-none transition-colors" type="text" id="name" name="name" placeholder="John Doe" required>
                            </div>
                            <!-- Phone -->
                            <div class="flex flex-col">
                                <label class="font-label-caps text-xs text-on-surface-variant mb-2" for="phone">Phone Number</label>
                                <input class="font-body-md bg-transparent border-b border-outline-variant py-2 focus:border-secondary-container focus:outline-none transition-colors" type="tel" id="phone" name="phone" placeholder="(512) 555-0191" required>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                            <!-- Email -->
                            <div class="flex flex-col">
                                <label class="font-label-caps text-xs text-on-surface-variant mb-2" for="email">Email Address</label>
                                <input class="font-body-md bg-transparent border-b border-outline-variant py-2 focus:border-secondary-container focus:outline-none transition-colors" type="email" id="email" name="email" placeholder="johndoe@example.com" required>
                            </div>
                            <!-- Service Type Dropdown -->
                            <div class="flex flex-col">
                                <label class="font-label-caps text-xs text-on-surface-variant mb-2" for="service">Service Needed</label>
                                <select class="font-body-md bg-transparent border-b border-outline-variant py-2 focus:border-secondary-container focus:outline-none transition-colors cursor-pointer text-on-surface" id="service" name="service" required>
                                    <option value="" disabled selected class="text-on-surface-variant">Select service...</option>
                                    <option value="Residential Roofing" class="bg-surface text-on-surface">Residential Estate Roofing</option>
                                    <option value="Commercial Roofing" class="bg-surface text-on-surface">Commercial Systems</option>
                                    <option value="Custom Metal Work" class="bg-surface text-on-surface">Custom Metal/Copper Work</option>
                                    <option value="Slate & Tile Repair" class="bg-surface text-on-surface">Slate & Tile Repair</option>
                                    <option value="Emergency Repair" class="bg-surface text-on-surface">Emergency Repair</option>
                                </select>
                            </div>
                        </div>

                        <!-- Address -->
                        <div class="flex flex-col">
                            <label class="font-label-caps text-xs text-on-surface-variant mb-2" for="address">Property Address</label>
                            <input class="font-body-md bg-transparent border-b border-outline-variant py-2 focus:border-secondary-container focus:outline-none transition-colors" type="text" id="address" name="address" placeholder="123 Main St, Austin, TX" required>
                        </div>

                        <!-- Message -->
                        <div class="flex flex-col">
                            <label class="font-label-caps text-xs text-on-surface-variant mb-2" for="message">Project Details</label>
                            <textarea class="font-body-md bg-transparent border-b border-outline-variant py-2 focus:border-secondary-container focus:outline-none transition-colors h-32 resize-none" id="message" name="message" placeholder="Please describe your project, roofing challenges, or storm damage..." required></textarea>
                        </div>

                        <!-- Alert Boxes for AJAX Status Feedback -->
                        <div id="form-success" class="hidden bg-secondary-container/10 border border-secondary-container p-4 rounded-sm text-secondary flex items-center gap-3">
                            <span class="material-symbols-outlined">check_circle</span>
                            <span class="font-body-md">Thank you! Your inspection request has been submitted successfully. We will call you shortly.</span>
                        </div>
                        <div id="form-error" class="hidden bg-error-container border border-error p-4 rounded-sm text-error flex items-center gap-3">
                            <span class="material-symbols-outlined">error</span>
                            <span class="font-body-md">Oops! Something went wrong. Please check your connection and try again.</span>
                        </div>

                        <!-- Submit Button -->
                        <button type="submit" id="submit-btn" class="w-full font-button-text text-lg bg-primary text-on-primary py-4 border border-secondary-container hover:bg-secondary-container hover:text-primary transition-all duration-300 flex items-center justify-center gap-3">
                            <span>Submit Inspection Request</span>
                            <span class="material-symbols-outlined text-xl">send</span>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </section>
</main>

<script>
    // AJAX Web3Forms Handler with Premium Feedback Controls
    const form = document.getElementById('contact-form');
    const successBox = document.getElementById('form-success');
    const errorBox = document.getElementById('form-error');
    const submitBtn = document.getElementById('submit-btn');

    form.addEventListener('submit', function(e) {
        e.preventDefault();
        
        // Hide prior status elements
        successBox.classList.add('hidden');
        errorBox.classList.add('hidden');
        
        // Visual loading state trigger
        submitBtn.disabled = true;
        const originalBtnText = submitBtn.innerHTML;
        submitBtn.innerHTML = `
            <span>Submitting Request...</span>
            <svg class="animate-spin h-5 w-5 text-current" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
        `;

        const formData = new FormData(form);
        const object = Object.fromEntries(formData);
        const json = JSON.stringify(object);

        fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            body: json
        })
        .then(async (response) => {
            let res = await response.json();
            if (response.status == 200) {
                // Success State
                successBox.classList.remove('hidden');
                form.reset();
            } else {
                // Failure State
                console.log(response);
                errorBox.classList.remove('hidden');
            }
        })
        .catch(error => {
            console.log(error);
            errorBox.classList.remove('hidden');
        })
        .then(() => {
            // Restore Original Button Visual State
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalBtnText;
            
            // Auto scroll to feedback messages
            if (!successBox.classList.contains('hidden')) {
                successBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
            } else if (!errorBox.classList.contains('hidden')) {
                errorBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        });
    });
</script>

<%- include('partials/footer') %>
