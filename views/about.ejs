        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            
            <!-- Standard 1 -->
            <div class="bg-primary p-8 border-b-2 border-secondary group hover:-translate-y-2 transition-all duration-300 rounded-sm animate-on-scroll">
                <span class="material-symbols-outlined text-secondary text-4xl mb-6">verified</span>
