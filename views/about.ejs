</section>

<!-- Company Legacy & Story Section -->
<section class="py-section-gap relative overflow-hidden">
    <div class="absolute -top-20 -left-10 font-display-lg text-[300px] text-secondary opacity-5 pointer-events-none z-0">"</div>
    <div class="max-w-7xl mx-auto px-margin-mobile md:px-margin-desktop relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-gutter items-center">
            <div class="order-2 lg:order-1 animate-on-scroll">
