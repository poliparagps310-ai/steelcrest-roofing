            <!-- Standard 2 -->
            <div class="bg-primary p-8 border-b-2 border-secondary group hover:-translate-y-2 transition-all duration-300 rounded-sm animate-on-scroll stagger-item" style="--order: 1;">
                <span class="material-symbols-outlined text-secondary text-4xl mb-6">architecture</span>
                <h3 class="font-button-text text-xl mb-3 text-on-primary">Quality</h3>
                <p class="font-body-md text-on-primary-container leading-relaxed">We source only industrial-grade materials for high-wind and heavy-storm performance.</p>
            </div>
            
            <!-- Standard 3 -->
            <div class="bg-primary p-8 border-b-2 border-secondary group hover:-translate-y-2 transition-all duration-300 rounded-sm animate-on-scroll stagger-item" style="--order: 2;">
